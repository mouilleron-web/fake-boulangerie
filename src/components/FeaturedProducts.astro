---
import painLevainImg from '../assets/images/pain-levain.jpg';
import croissantsImg from '../assets/images/croissants.jpg';
import tarteFruitsImg from '../assets/images/tarte-fruits.jpg';

const products = [
  {
    name: "Pain au levain",
    description: "Notre signature. Fermentation longue de 24 heures, croûte épaisse et croustillante, mie alvéolée et parfumée.",
    badge: "Notre spécialité",
    image: painLevainImg.src,
    alt: "Miche de pain au levain avec une croûte dorée et craquelée",
  },
  {
    name: "Croissant pur beurre",
    description: "Feuilletage traditionnel au beurre AOP Charentes-Poitou. Doré, croustillant à l'extérieur, fondant à l'intérieur.",
    badge: "Beurre AOP",
    image: croissantsImg.src,
    alt: "Croissants dorés tout juste sortis du four",
  },
  {
    name: "Tarte aux fruits de saison",
    description: "Pâte sablée maison, crème pâtissière onctueuse et fruits frais du marché. La recette change avec les saisons.",
    badge: "Fruits frais",
    image: tarteFruitsImg.src,
    alt: "Tarte aux fruits frais décorée avec soin",
  },
];
---

<section class="bg-parchment py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="text-gold font-semibold mb-3 text-sm tracking-[0.2em] uppercase">Faits maison, chaque jour</p>
      <h2 class="text-3xl md:text-4xl font-bold">Nos spécialités</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {products.map((product) => (
        <div class="group bg-flour rounded-2xl shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden">
          <div class="h-56 overflow-hidden">
            <img
              src={product.image}
              alt={product.alt}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="p-6">
            <span class="inline-block px-3 py-1 bg-gold/10 text-gold-dark text-xs font-semibold rounded-full mb-3">
              {product.badge}
            </span>
            <h3 class="font-heading text-xl font-bold mb-2">{product.name}</h3>
            <p class="text-crust text-sm leading-relaxed">{product.description}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a
        href="/produits"
        class="inline-flex items-center gap-2 text-gold font-semibold hover:text-gold-dark transition-colors duration-200"
      >
        Voir tous nos produits
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
