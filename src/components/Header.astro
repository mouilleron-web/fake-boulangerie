---
const navLinks = [
  { label: "Accueil", href: "/" },
  { label: "Nos Produits", href: "/produits" },
  { label: "Notre Histoire", href: "/histoire" },
  { label: "Contact", href: "/contact" },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-espresso/95 backdrop-blur-md border-b border-espresso-light">
  <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2">
      <svg class="w-8 h-8 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2C10 6 7 8 7 12c0 3 2 5 5 5s5-2 5-5c0-4-3-6-5-10z" />
        <path d="M12 17v5" />
        <path d="M9 22h6" />
      </svg>
      <span class="font-heading text-lg">
        <span class="text-flour font-bold">La Boulangerie</span>
        <span class="text-gold ml-1">du Quartier</span>
      </span>
    </a>

    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              "transition-colors duration-200 font-medium pb-1",
              currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href))
                ? "text-gold border-b-2 border-gold"
                : "text-warm-gray hover:text-gold"
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
    >
      <span class="block w-6 h-0.5 bg-flour transition-all duration-300" id="bar1"></span>
      <span class="block w-6 h-0.5 bg-flour transition-all duration-300" id="bar2"></span>
      <span class="block w-6 h-0.5 bg-flour transition-all duration-300" id="bar3"></span>
    </button>
  </nav>

  <div id="mobile-menu" class="md:hidden hidden bg-espresso border-t border-espresso-light">
    <ul class="flex flex-col items-center gap-6 py-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              "mobile-link text-lg transition-colors duration-200 font-medium",
              currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href))
                ? "text-gold"
                : "text-warm-gray hover:text-gold"
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const bar1 = document.getElementById('bar1')!;
  const bar2 = document.getElementById('bar2')!;
  const bar3 = document.getElementById('bar3')!;

  toggle.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    menu.classList.toggle('hidden');
    bar1.classList.toggle('rotate-45');
    bar1.classList.toggle('translate-y-2');
    bar2.classList.toggle('opacity-0');
    bar3.classList.toggle('-rotate-45');
    bar3.classList.toggle('-translate-y-2');
  });

  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      bar1.classList.remove('rotate-45', 'translate-y-2');
      bar2.classList.remove('opacity-0');
      bar3.classList.remove('-rotate-45', '-translate-y-2');
    });
  });
</script>
